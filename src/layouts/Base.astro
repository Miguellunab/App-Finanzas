---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'FinanzasAI' } = Astro.props;
const description = 'App web ligera para revisar balance, ingresos, gastos y probar transcripcion por microfono.';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a0a0f" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="FinanzasAI" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta property="og:title" content={`${title} - FinanzasAI`} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <title>{title} - FinanzasAI</title>
  </head>
  <body>
    <slot />
  </body>
</html>
